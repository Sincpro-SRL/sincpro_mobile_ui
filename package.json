    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "sincpro_mobile_ui",
    "!**/__tests__",
    "!**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "clean": "rm -rf lib",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yml,yaml,md}\" --ignore-path .prettierignore --ignore-unknown",
    "check": "yarn lint && yarn typecheck"
  },
  "react-native-builder-bob": {
    "source": "sincpro_mobile_ui",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "prettier": {
    "printWidth": 94
  },
  "keywords": [
    "react-native",
    "expo",
    "design-system",
    "ui",
    "nativewind",
    "sincpro"
  ],
  "repository": "https://github.com/Sincpro-SRL/sincpro_mobile_ui",
  "author": "Gutierrez, Andres <andres.gutierrez@sincpro.com.bo>",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "nativewind": ">=4",
    "react-hook-form": ">=7",
    "react-native-reanimated": "*",
