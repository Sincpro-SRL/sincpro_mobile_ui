{
  "name": "@sincpro/mobile-ui",
  "version": "0.1.2",
  "description": "Sincpro Mobile design system: generic, presentational React Native components (no domain logic)",
  "source": "./sincpro_mobile_ui/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./sincpro_mobile_ui/index.ts",
  "types": "./lib/typescript/index.d.ts",
