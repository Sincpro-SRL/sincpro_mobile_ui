{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "lib": ["esnext", "dom"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "paths": {
      "@sincpro/mobile-ui": ["./sincpro_mobile_ui/index.ts"],
      "@sincpro/mobile-ui/*": ["./sincpro_mobile_ui/*"]
    }
  },
  "include": [
    "sincpro_mobile_ui/**/*.ts",
    "sincpro_mobile_ui/**/*.tsx",
    "nativewind-env.d.ts",
    "assets-fonts.d.ts"
  ],
  "exclude": ["node_modules", "dist"],
  "extends": "expo/tsconfig.base"
}
